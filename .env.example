# Required — one key powers both the agent and the evaluators (different model families).
GROQ_API_KEY=gsk_...          # agent: qwen/qwen3-32b · judge + RAGAS: llama-3.3-70b-versatile

# Required for regression tracking dashboards.
WANDB_API_KEY=...
WANDB_PROJECT=rag-eval-harness

# Optional — set WANDB_MODE=offline to log locally without a W&B account.
# WANDB_MODE=offline

# Embeddings run locally via sentence-transformers (all-MiniLM-L6-v2) — no key needed.

# Disable chromadb's broken telemetry (PostHog API mismatch spams stderr).
ANONYMIZED_TELEMETRY=False
